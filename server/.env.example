# =============================================================================
# SyncSpace Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running locally.
# NEVER commit your actual .env file to version control.
# All secrets marked [SECRET] must be kept private and never committed.
# =============================================================================

# --- Node Environment ---
# Use "development" locally, "production" on Render/cloud.
NODE_ENV=development

# --- Server Port ---
# The port the backend server listens on.
PORT=5005

# --- MongoDB Connection URI [SECRET] ---
# Full MongoDB Atlas connection string including username, password, and database.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/syncspace

# --- JWT Access Token Secret [SECRET] ---
# Long random string used to sign short-lived access tokens (15m expiry).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_jwt_access_secret_here

# --- JWT Refresh Token Secret [SECRET] ---
# Long random string used to sign long-lived refresh tokens (7d expiry).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# --- JWT Expiry Configuration ---
# Access token lifetime (short — 15 minutes recommended)
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token lifetime (long — 7 days recommended)
JWT_REFRESH_EXPIRES_IN=7d

# --- Client URL (for CORS) ---
# Comma-separated list of allowed frontend origins.
# Local: http://localhost:5173
# Production: https://syncspace-frontend-05u3.onrender.com
# Multiple: https://syncspace-frontend-05u3.onrender.com,http://localhost:5173
CLIENT_URL=http://localhost:5173

# --- App URL ---
# The public URL of this backend server (used for email links, etc.).
APP_URL=http://localhost:5005

# --- Cloudinary (File / Avatar Uploads) [SECRET] ---
# Sign up at https://cloudinary.com to get these credentials.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- SMTP Email (Nodemailer) [SECRET] ---
# Used for sending invitation emails, password resets, etc.
# You can use Gmail (requires App Password), SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=SyncSpace <noreply@syncspace.io>
